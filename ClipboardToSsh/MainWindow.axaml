<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="500"
        x:Class="ClipboardToSsh.MainWindow"
        Title="Clipboard to SSH"
        Width="650"
        Height="500"
        MinWidth="650"
        MinHeight="500">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="Transparent" Padding="5">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <TextBlock Text="Host:" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="HostComboBox" Grid.Column="1"/>
                <Button Grid.Column="2" Content="Refresh Hosts" Click="RefreshHosts_Click"
                        Margin="10,0,0,0" Padding="10,5"/>
                <ToggleButton x:Name="PollingToggle" Grid.Column="3" Content="Paused"
                              IsChecked="False" Click="PollingToggle_Click"
                              MinWidth="90" Margin="10,0,0,0" Padding="10,5"/>
                <ToggleButton x:Name="ImageOnlyToggle" Grid.Column="4" Content="Images Only"
                              IsChecked="False" Click="ImageOnlyToggle_Click"
                              MinWidth="90" Margin="10,0,0,0" Padding="10,5"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#333" Padding="5">
            <StackPanel>
                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,5">
                    <TextBlock x:Name="FilenameText" Text=""
                               VerticalAlignment="Center"
                               Foreground="#0F0" FontSize="12" FontFamily="Consolas"
                               FontWeight="Bold"/>
                    <Button x:Name="CopyFilenameButton" Grid.Column="1" Content="Copy"
                            Click="CopyFilename_Click"
                            Padding="10,5" Margin="0,0,10,0"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <TextBlock x:Name="StatusText" Text="Ready"
                               VerticalAlignment="Center"
                               Foreground="White"/>
                    <Button x:Name="SaveLocalButton" Grid.Column="1" Content="Save Local"
                            Click="SaveLocal_Click"
                            Padding="10,5" Margin="0,0,10,0"/>
                    <Button x:Name="TransferButton" Grid.Column="2" Content="Transfer"
                            Click="Transfer_Click"
                            Padding="15,5"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Margin="5,5,5,10" Background="#222" CornerRadius="5">
            <Panel>
                <ScrollViewer>
                    <TextBlock x:Name="ContentText"
                               TextWrapping="Wrap"
                               Foreground="White"
                               Margin="10"
                               IsVisible="False"/>
                </ScrollViewer>
                <Image x:Name="ContentImage"
                       Stretch="Uniform"
                       Margin="10"
                       IsVisible="False"
                       RenderOptions.BitmapInterpolationMode="MediumQuality"/>
            </Panel>
        </Border>
    </DockPanel>
</Window>
